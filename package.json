{
  "name": "drools-formatter",
  "displayName": "Drools Formatter",
  "publisher": "jhhtaylor",
  "author": {
    "name": "Jon Taylor",
    "email": "jhhtaylor@gmail.com"
  },
  "description": "Formats Drools (.drl) rule files in VS Code.",
  "icon": "media/drools-formatter.png",
  "galleryBanner": {
    "color": "#FF914D",
    "theme": "dark"
  },
  "homepage": "https://github.com/jhhtaylor/drools-formatter/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhhtaylor/drools-formatter"
  },
  "bugs": {
    "url": "https://github.com/jhhtaylor/drools-formatter/issues",
    "email": "jhhtaylor@gmail.com"
  },
  "sponsor": {
    "url": "https://www.buymeacoffee.com/jhhtaylor"
  },
  "version": "0.2.3",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "Drools",
    "drl",
    "rules",
    "formatter",
    "code style"
  ],
  "activationEvents": [
    "onLanguage:drools"
  ],
  "contributes": {
    "languages": [
      {
        "id": "drools",
        "aliases": [
          "Drools",
          "drools"
        ],
        "extensions": [
          ".drl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Drools Formatter",
      "properties": {
        "droolsFormatter.indentation.mode": {
          "type": "string",
          "enum": [
            "editor",
            "spaces",
            "tabs"
          ],
          "default": "editor",
          "description": "Where to take indentation from. 'editor' uses VS Code's editor settings; 'spaces' forces spaces; 'tabs' forces tabs."
        },
        "droolsFormatter.indentation.size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8,
          "default": 2,
          "description": "How many spaces to use when mode is 'spaces'."
        }
      }
    },
    "configurationDefaults": {
      "[drools]": {
        "editor.defaultFormatter": "jhhtaylor.drools-formatter"
      }
    }
  },
  "main": "./dist/extension.js",
  "bin": {
    "drools-fmt": "./dist/cli.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npx webpack",
    "watch": "npx webpack --watch",
    "package": "npx webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "echo no-lint",
    "test": "node ./out/test/keywords.test.js && node ./out/test/spacing.test.js && node ./out/test/attributes.test.js && node ./out/test/query.test.js && node ./out/test/indentation.test.js",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --outfile=dist/cli.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.8.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
